#!/bin/bash
# miru: sb-wifi | kiqkuk

ICON="󰤮"
LABEL="Offline"

for eth in /sys/class/net/e*; do
    if [[ -f "$eth/operstate" ]]; then
        read -r state < "$eth/operstate"
        if [[ "$state" == "up" ]]; then
            ICON="󰈀"
            LABEL="Eth"
            break
        fi
    fi
done

if [[ "$LABEL" == "Offline" ]]; then
    for wlan in /sys/class/net/w*; do
        if [[ -f "$wlan/operstate" ]]; then
            read -r state < "$wlan/operstate"
            if [[ "$state" == "up" ]]; then
                ICON="󰖩"
                LABEL="Wifi"
                break
            fi
        fi
    done
fi

echo "$ICON $LABEL"
